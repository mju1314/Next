{
  "name": "next-personal-execution-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:unit": "tsx --test tests/recommendation.test.ts tests/recommendation-history.test.ts tests/work-sessions.test.ts",
    "test:integration": "tsx --test tests/integration.test.ts",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "apk:debug": "npm run build && cap sync android && cd android && ./gradlew assembleDebug",
    "db:apply": "node scripts/apply-sqlite-migration.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.10.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@vitejs/plugin-react": "^5.1.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "10.4.20",
    "postcss": "latest",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "^7.3.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
